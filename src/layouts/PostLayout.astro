---
import BaseLayout from "./BaseLayout.astro";
import PostNav from "@/components/PostNav.astro";
import PostComments from "@/components/PostComments.astro";
import { getReadingTime } from "@/utils/reading-time";
import { getAllPosts } from "@/utils/posts";
import { href } from "@/utils/paths";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, math, image } = post.data;

const { Content, headings } = await post.render();
const readingTime = getReadingTime(post.body ?? "");

const allPosts = await getAllPosts();
const idx = allPosts.findIndex((p) => p.id === post.id);
const prevPost = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;
const nextPost = idx > 0 ? allPosts[idx - 1] : null;

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout title={title} description={description} image={image?.url} math={math}>
  <article class="post-layout">
    <header class="mb-12 max-w-[720px]">
      {tags.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a href={href(`/tags/${tag.toLowerCase()}/`)} class="tag-link">
              {tag}
            </a>
          ))}
        </div>
      )}

      <h1
        class="heading-page text-3xl leading-tight tracking-tight sm:text-4xl lg:text-5xl"
        transition:name={`post-title-${post.slug}`}
      >
        {title}
      </h1>

      <div class="text-muted-sm mt-4 flex flex-wrap items-center gap-3">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {formatDate(updatedDate)}</span>
          </>
        )}
        <span aria-hidden="true">·</span>
        <span>{readingTime}</span>
      </div>
    </header>

    <div class="flex gap-12">
      <div class="min-w-0 max-w-[720px] flex-1">
        <div class="prose">
          <Content />
        </div>

        <PostNav prev={prevPost} next={nextPost} />
        <PostComments />
      </div>

      {tocHeadings.length > 0 && (
        <aside class="toc-sidebar hidden w-56 shrink-0 lg:block" aria-label="Table of contents">
          <div class="sticky top-24">
            <p class="text-muted-sm mb-3 text-xs font-semibold uppercase tracking-widest">
              On this page
            </p>
            <nav>
              <ul class="space-y-1.5">
                {tocHeadings.map((h) => (
                  <li style={h.depth === 3 ? "padding-left: 0.75rem;" : ""}>
                    <a
                      href={`#${h.slug}`}
                      class="toc-link block text-xs leading-relaxed transition-colors duration-200"
                      data-slug={h.slug}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .tag-link {
    display: inline-block;
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    background: var(--accent-subtle);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .tag-link:hover {
    background: var(--accent-glow);
  }

  .toc-link {
    color: var(--text-muted);
  }

  .toc-link:hover,
  .toc-link.active {
    color: var(--accent);
  }

  .toc-link.active {
    font-weight: 600;
  }
</style>

<script>
  function initTOC() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-link");
    if (tocLinks.length === 0) return;

    const headingEls = Array.from(tocLinks)
      .map((link) => link.dataset.slug ? document.getElementById(link.dataset.slug) : null)
      .filter(Boolean) as HTMLElement[];

    function updateActive() {
      let active = headingEls[0];
      for (const el of headingEls) {
        if (el.getBoundingClientRect().top <= 100) active = el;
      }
      tocLinks.forEach((link) => {
        link.classList.toggle("active", link.dataset.slug === active?.id);
      });
    }

    window.addEventListener("scroll", updateActive, { passive: true });
    updateActive();
  }

  initTOC();
  document.addEventListener("astro:after-swap", initTOC);
</script>
