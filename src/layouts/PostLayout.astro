---
import BaseLayout from "./BaseLayout.astro";
import PostNav from "@/components/PostNav.astro";
import PostComments from "@/components/PostComments.astro";
import PostReadingPath from "@/components/PostReadingPath.astro";
import ReadingTime from "@/components/ReadingTime.astro";
import { getAllPosts, type BlogPost } from "@/utils/posts";
import { getReadingPathsForPost } from "@/utils/reading-paths";
import { getPostSocialImage, getPostSocialImageAlt } from "@/utils/social-image";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags, math } = post.data;

const { Content, headings } = await post.render();
const socialImage = getPostSocialImage(post);
const socialImageAlt = getPostSocialImageAlt(post);
const readingPaths = await getReadingPathsForPost(post.slug);

const allPosts = await getAllPosts();
const idx = allPosts.findIndex((p) => p.id === post.id);
const prevPost = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;
const nextPost = idx > 0 ? allPosts[idx - 1] : null;

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString("ko-KR", { year: "numeric", month: "long", day: "numeric" });
}
---

<BaseLayout title={title} description={description} image={socialImage} imageAlt={socialImageAlt} math={math} ogType="article" publishedTime={pubDate} modifiedTime={updatedDate} tags={tags}>
  <article class="post-layout" aria-labelledby="post-article-title">
    <header class="mb-12 max-w-[720px]">
      <p class="sr-only">{description}</p>
      {tags.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="tag-chip">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1
        id="post-article-title"
        class="heading-page text-3xl leading-tight tracking-tight sm:text-4xl lg:text-5xl"
        transition:name={`post-title-${post.slug}`}
      >
        {title}
      </h1>

      <div class="text-muted-sm mt-4 flex flex-wrap items-center gap-3">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>수정 {formatDate(updatedDate)}</span>
          </>
        )}
        <span aria-hidden="true">·</span>
        <ReadingTime content={post.body} />
      </div>
    </header>

    <div class="flex gap-12">
      <div class="min-w-0 max-w-[720px] flex-1">
        <div class="prose">
          <Content />
        </div>

        <PostReadingPath currentSlug={post.slug} paths={readingPaths} />
        <PostNav prev={prevPost} next={nextPost} />
        <PostComments
          identifier={post.slug}
          url={new URL(Astro.url.pathname, Astro.site).toString()}
          title={title}
        />
      </div>

      {tocHeadings.length > 0 && (
        <aside class="toc-sidebar hidden w-56 shrink-0 lg:block" aria-labelledby="post-toc-heading">
          <div class="toc-sticky">
            <p id="post-toc-heading" class="text-muted-sm mb-3 text-xs font-semibold uppercase tracking-widest">
              목차
            </p>
            <nav aria-label="이 글의 목차">
              <ul class="space-y-1.5">
                {tocHeadings.map((h) => (
                  <li class:list={[{ "toc-indent": h.depth === 3 }]}>
                    <a
                      href={`#${h.slug}`}
                      class="toc-link block text-xs leading-relaxed transition-colors duration-200"
                      data-slug={h.slug}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .tag-chip {
    display: inline-block;
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    background: var(--accent-subtle);
  }

  .toc-sticky {
    position: sticky;
    /* Match the header's own top inset so the TOC sticks just below
       the (safe-area-aware) fixed header. */
    top: calc(6rem + env(safe-area-inset-top));
  }

  .toc-indent {
    padding-left: 0.75rem;
  }

  .toc-link {
    color: var(--text-muted);
  }

  .toc-link:hover,
  .toc-link.active {
    color: var(--accent);
  }

  .toc-link.active {
    font-weight: 600;
  }
</style>

<script>
  let controller: AbortController | null = null;

  function initTOC() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-link");

    // Abort the previous page's listener even when this page has no TOC,
    // otherwise the stale handler keeps firing on every scroll.
    controller?.abort();
    if (tocLinks.length === 0) return;
    controller = new AbortController();

    const headingEls = Array.from(tocLinks)
      .map((link) => link.dataset.slug ? document.getElementById(link.dataset.slug) : null)
      .filter(Boolean);

    function updateActive() {
      let active = headingEls[0];
      for (const el of headingEls) {
        if (el.getBoundingClientRect().top <= 100) active = el;
      }
      tocLinks.forEach((link) => {
        link.classList.toggle("active", link.dataset.slug === active?.id);
      });
    }

    window.addEventListener("scroll", updateActive, {
      passive: true,
      signal: controller.signal,
    });
    updateActive();
  }

  initTOC();
  document.addEventListener("astro:after-swap", initTOC);
</script>
