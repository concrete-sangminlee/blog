---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ScrollProgress from "@/components/ScrollProgress.astro";
import SearchModal from "@/components/SearchModal";
import { ClientRouter } from "astro:transitions";
import { SITE } from "@/data/site.config";

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  math?: boolean;
  ogType?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: readonly string[];
  noIndex?: boolean;
}

const {
  title,
  description = SITE.description,
  image,
  imageAlt,
  math = false,
  ogType = "website",
  publishedTime,
  modifiedTime,
  tags,
  noIndex = false,
} = Astro.props;
---

<html lang={SITE.lang}>
  <head>
    <!-- Set the theme before first paint so dark-mode visitors never see a
         light-theme flash while the rest of <head> is parsing. Saved
         preference wins; otherwise follow the OS. Also syncs the
         theme-color meta so the mobile URL bar matches the chosen theme. -->
    <script is:inline>
      (function () {
        var chosen = null;
        try {
          var stored = localStorage.getItem("theme");
          if (stored === "dark" || stored === "light") chosen = stored;
        } catch (_) {}
        if (!chosen && window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
          chosen = "dark";
        }
        if (chosen === "dark") {
          document.documentElement.setAttribute("data-theme", "dark");
        }
        // Defer the theme-color meta update until the head element exists;
        // the meta is written by BaseHead.astro right after this script.
        document.addEventListener("DOMContentLoaded", function () {
          var meta = document.getElementById("theme-color-meta");
          if (meta) meta.setAttribute("content", chosen === "dark" ? "#08080a" : "#fafaf8");
        });
      })();
    </script>
    <BaseHead title={title} description={description} image={image} imageAlt={imageAlt} math={math} ogType={ogType} publishedTime={publishedTime} modifiedTime={modifiedTime} tags={tags} noIndex={noIndex} />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">본문으로 건너뛰기</a>
    <ScrollProgress />
    <Header />
    <SearchModal client:only="react" basePath={SITE.base} transition:persist />

    <main id="main-content" class="mx-auto max-w-[1200px] px-6 py-8">
      <slot />
    </main>

    <Footer />
  </body>
</html>
