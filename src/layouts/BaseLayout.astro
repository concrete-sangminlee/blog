---
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ScrollProgress from "@/components/ScrollProgress.astro";
import SearchModal from "@/components/SearchModal";
import { ClientRouter } from "astro:transitions";
import { SITE } from "@/data/site.config";

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  math?: boolean;
  ogType?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const {
  title,
  description = SITE.description,
  image,
  imageAlt,
  math = false,
  ogType = "website",
  publishedTime,
  modifiedTime,
  tags,
} = Astro.props;
---

<html lang={SITE.lang}>
  <head>
    <!-- Set the theme before first paint so dark-mode visitors never see a
         light-theme flash while the rest of <head> is parsing. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          if (stored) document.documentElement.setAttribute("data-theme", stored);
        } catch (_) {}
      })();
    </script>
    <BaseHead title={title} description={description} image={image} imageAlt={imageAlt} math={math} ogType={ogType} publishedTime={publishedTime} modifiedTime={modifiedTime} tags={tags} />
    <ClientRouter />
  </head>
  <body>
    <ScrollProgress />
    <Header />
    <SearchModal client:only="react" basePath={SITE.base} />

    <main class="mx-auto max-w-[1200px] px-6 py-8">
      <slot />
    </main>

    <Footer />
  </body>
</html>
