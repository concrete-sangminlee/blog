---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EmptyState from "@/components/EmptyState.astro";
import PageIntro from "@/components/PageIntro.astro";
import PostCard from "@/components/PostCard.astro";
import ReadingPathCard from "@/components/ReadingPathCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { getAllPosts, getFeaturedPosts } from "@/utils/posts";
import { getFeaturedReadingPaths } from "@/utils/reading-paths";
import { SITE } from "@/data/site.config";
import { href } from "@/utils/paths";

const allPosts = await getAllPosts();
const featuredPosts = await getFeaturedPosts();
const featuredPaths = await getFeaturedReadingPaths();
const featuredSlugs = new Set(featuredPosts.map((post) => post.slug));
const recentPosts = allPosts.filter((post) => !featuredSlugs.has(post.slug)).slice(0, 8);
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <section class="home-intro" aria-labelledby="home-hero-title">
    <PageIntro
      headingId="home-hero-title"
      eyebrow="Sang Min Lee's Blog"
      title="구조공학과 인공지능의 기록"
      description="구조공학과 인공지능의 교차점에서 기록을 남기기 위한 곳입니다."
    />
    {(allPosts.length > 0 || featuredPaths.length > 0) && (
      <div class="home-actions">
        {allPosts.length > 0 && (
          <a href={href("/posts/")} class="btn-accent">
            전체 글 보기
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        )}
        {featuredPaths.length > 0 && <a href={href("/start-here/")} class="btn-ghost">읽기 경로</a>}
      </div>
    )}
  </section>

  {featuredPaths.length > 0 && (
    <section class="content-section" aria-labelledby="home-start-here">
      <SectionHeader headingId="home-start-here" title="읽기 경로" />
      <div class="grid gap-4 md:grid-cols-3">
        {featuredPaths.slice(0, 3).map((path, i) => (
          <ReadingPathCard path={path} index={i} compact />
        ))}
      </div>

      <div class="mt-8 text-center">
        <a href={href("/start-here/")} class="view-all">
          모든 읽기 경로 보기
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>
  )}

  {featuredPosts.length > 0 && (
    <section class="content-section" aria-labelledby="home-featured">
      <SectionHeader headingId="home-featured" title="추천 글" />
      <div class="space-y-1">
        {featuredPosts.slice(0, 3).map((post, i) => (
          <PostCard post={post} index={i} />
        ))}
      </div>
    </section>
  )}

  <section class="content-section" aria-labelledby="home-recent">
    <SectionHeader headingId="home-recent" title="최근 글" />
    {recentPosts.length > 0 ? (
      <div class="space-y-1">
        {recentPosts.map((post, i) => (
          <PostCard post={post} index={i} />
        ))}
      </div>
    ) : (
      <EmptyState />
    )}

    {allPosts.length > 8 && (
      <div class="mt-8 text-center">
        <a href={href("/posts/")} class="view-all">
          전체 글 보기
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .home-intro {
    padding: 3rem 0 3.5rem;
  }

  @media (min-width: 640px) {
    .home-intro { padding: 4rem 0 4.5rem; }
  }

  .home-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: -1.75rem;
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .view-all:hover {
    color: var(--accent-hover);
    gap: 0.6rem;
  }
</style>
