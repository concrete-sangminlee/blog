---
import ListLayout from "@/layouts/ListLayout.astro";
import { getAllTags } from "@/utils/posts";
import { href } from "@/utils/paths";

const tags = await getAllTags();
---

<ListLayout title="태그" description="검증된 글을 주제별로 찾아볼 수 있는 태그 모음.">
  {tags.size > 0 ? (
    <div class="flex flex-wrap gap-3">
      {[...tags.entries()].map(([tag, count]) => (
        <a href={href(`/tags/${tag.toLowerCase()}/`)} class="tag-chip" aria-label={`${tag} 태그의 글 ${count}편 보기`}>
          <span class="tag-chip-label" aria-hidden="true">{tag}</span>
          <span class="tag-chip-count" aria-hidden="true">{count}</span>
        </a>
      ))}
    </div>
  ) : (
    <p class="empty-state">검증을 마친 글이 발행되면 태그가 생깁니다.</p>
  )}
</ListLayout>

<style>
  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .tag-chip:hover {
    border-color: var(--accent);
    background: var(--accent-subtle);
  }

  .tag-chip:hover .tag-chip-label {
    color: var(--accent);
  }

  .tag-chip-label {
    transition: color 0.2s ease;
  }

  .tag-chip-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.375rem;
    border-radius: 9999px;
    background: var(--accent-subtle);
    color: var(--accent);
    font-size: 0.75rem;
  }
</style>
