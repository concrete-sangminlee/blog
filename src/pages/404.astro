---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { href } from "@/utils/paths";
---

<BaseLayout title="404 - Page Not Found" description="페이지를 찾을 수 없습니다">
  <section class="flex min-h-[60vh] flex-col items-center justify-center text-center">
    <span class="heading-page text-8xl sm:text-9xl" style="color: var(--border);">
      404
    </span>
    <h1 class="heading-page mt-4 text-2xl sm:text-3xl">
      Page Not Found
    </h1>
    <p class="mt-3 text-base" style="color: var(--text-secondary);">
      찾으시는 페이지가 존재하지 않거나 이동되었습니다.
    </p>
    <a href={href("/")} class="btn-accent mt-8">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Go Home
    </a>
  </section>
</BaseLayout>
