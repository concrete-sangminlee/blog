---
import ListLayout from "@/layouts/ListLayout.astro";
import ReadingPathCard from "@/components/ReadingPathCard.astro";
import { getReadingPaths, getReadingPathStats } from "@/utils/reading-paths";

const paths = await getReadingPaths();
const stats = getReadingPathStats(paths);
---

<ListLayout title="Start Here" description="처음 오는 독자를 위한 읽기 경로">
  <div class="mb-10">
    <p class="intro-copy">
      처음부터 모든 글을 시간순으로 읽기보다, 비슷한 문제끼리 묶인 흐름으로 따라가면 이 블로그의 맥락이 더 빨리 잡힙니다.
    </p>

    <div class="intro-stats" aria-label="Reading path stats">
      <span>{stats.pathCount} curated paths</span>
      <span>{stats.coveredPostCount} posts connected</span>
    </div>
  </div>

  <section class="grid gap-4 md:grid-cols-2" aria-label="Reading paths">
    {paths.map((path, index) => (
      <ReadingPathCard path={path} index={index} />
    ))}
  </section>
</ListLayout>

<style>
  .intro-copy {
    max-width: 52rem;
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .intro-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .intro-stats span {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--text-muted);
  }
</style>
