---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getReadingPaths } from "@/utils/reading-paths";
import { href } from "@/utils/paths";
import type { ResolvedReadingPath } from "@/utils/reading-paths";

export async function getStaticPaths() {
  const paths = await getReadingPaths();
  return paths.map((path) => ({
    params: { id: path.id },
    props: { path },
  }));
}

interface Props {
  path: ResolvedReadingPath;
}

const { path } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}
---

<BaseLayout title={`${path.title} | Start Here`} description={path.description}>
  <section class="mb-12 max-w-3xl">
    <p class="path-kicker">Reading Path</p>
    <h1 class="heading-page text-3xl tracking-tight sm:text-4xl lg:text-5xl">{path.title}</h1>
    <p class="path-lead">{path.description}</p>
    <div class="path-meta">
      <span>{path.posts.length} posts</span>
    </div>
    <div class="accent-line mt-6" aria-hidden="true" />
  </section>

  <section class="path-list" aria-label={`${path.title} posts`}>
    {path.posts.map((post, index) => (
      <article class="path-step">
        <div class="path-step-index">{String(index + 1).padStart(2, "0")}</div>
        <div class="path-step-body">
          <div class="path-step-meta">
            <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            <span aria-hidden="true">·</span>
            <span>{post.data.tags.slice(0, 3).join(" / ")}</span>
          </div>
          <h2 class="path-step-title">
            <a href={href(`/${post.slug}/`)}>{post.data.title}</a>
          </h2>
          <p class="path-step-desc">{post.data.description}</p>
        </div>
      </article>
    ))}
  </section>

  <div class="mt-12">
    <a href={href("/start-here/")} class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      Back to all paths
    </a>
  </div>
</BaseLayout>

<style>
  .path-kicker {
    margin: 0 0 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
  }

  .path-lead {
    margin: 1rem 0 0;
    max-width: 46rem;
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1rem;
    text-wrap: pretty;
  }

  .path-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .path-meta span {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--text-muted);
  }

  .path-list {
    display: grid;
    gap: 1rem;
  }

  .path-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: start;
    padding: 1.1rem 0 1.1rem;
    border-top: 1px solid var(--border);
  }

  .path-step:last-child {
    border-bottom: 1px solid var(--border);
  }

  .path-step-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    background: var(--accent-subtle);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .path-step-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .path-step-title {
    margin: 0.5rem 0 0;
    font-family: var(--font-heading);
    font-size: 1.3rem;
    line-height: 1.35;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .path-step-title a {
    color: var(--text-primary);
    text-decoration: none;
  }

  .path-step-title a:hover {
    color: var(--accent);
  }

  .path-step-desc {
    margin: 0.55rem 0 0;
    color: var(--text-secondary);
    line-height: 1.7;
    text-wrap: pretty;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--accent-hover);
  }

  @media (max-width: 639px) {
    .path-step {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }
</style>
