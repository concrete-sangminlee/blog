---
import type { ResolvedReadingPath } from "@/utils/reading-paths";
import { href } from "@/utils/paths";

interface Props {
  path: ResolvedReadingPath;
  index?: number;
  compact?: boolean;
}

const { path, index = 0, compact = false } = Astro.props;
const previewPosts = path.posts.slice(0, compact ? 2 : 3);
---

<article class="path-card" style={`animation-delay: ${index * 70}ms;`}>
  <a href={href(`/start-here/${path.id}/`)} class="path-card-link">
    <div class="path-card-meta">
      <span class="path-card-label">Reading Path</span>
      <span class="path-card-count">{path.posts.length} posts</span>
    </div>

    <h3 class="path-card-title">{path.title}</h3>
    <p class="path-card-desc">{path.description}</p>

    <ul class="path-card-preview" aria-label="Preview posts">
      {previewPosts.map((post) => (
        <li>{post.data.title}</li>
      ))}
    </ul>

    <span class="path-card-cta">
      Open path
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </span>
  </a>
</article>

<style>
  .path-card {
    opacity: 0;
    animation: fadeIn 0.45s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .path-card-link {
    display: grid;
    min-height: 100%;
    gap: 0.8rem;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .path-card-link:hover {
    border-color: var(--border-hover);
    background: var(--bg-surface-hover);
    transform: translateY(-1px);
    color: inherit;
  }

  .path-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .path-card-label {
    color: var(--accent);
  }

  .path-card-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    line-height: 1.35;
    letter-spacing: -0.015em;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .path-card-desc {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.65;
    text-wrap: pretty;
  }

  .path-card-preview {
    margin: 0;
    padding-left: 1rem;
    color: var(--text-secondary);
    font-size: 0.86rem;
    line-height: 1.65;
  }

  .path-card-preview li + li {
    margin-top: 0.18rem;
  }

  .path-card-cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--accent);
  }
</style>
