---
interface Props {
  tags: string[];
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<nav class="tag-list-wrap" aria-label="Tags">
  <ul class="tag-list">
    {tags.map((tag) => {
      const isActive = activeTag?.toLowerCase() === tag.toLowerCase();
      return (
        <li>
          <a
            href={`${base}tags/${tag.toLowerCase()}/`}
            class:list={["tag-link", { active: isActive }]}
            aria-current={isActive ? "page" : undefined}
          >
            {tag}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<style>
  .tag-list-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.25rem 0;
  }

  .tag-list-wrap::-webkit-scrollbar {
    display: none;
  }

  .tag-list {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    white-space: nowrap;
  }

  .tag-link {
    display: inline-block;
    padding: 0.3125rem 0.875rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: 9999px;
    text-decoration: none;
    transition:
      color 0.15s ease,
      background-color 0.15s ease,
      border-color 0.15s ease;
    white-space: nowrap;
  }

  .tag-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-subtle);
  }

  .tag-link.active {
    color: var(--accent);
    background: var(--accent-subtle);
    border-color: var(--accent);
    font-weight: 600;
  }
</style>
