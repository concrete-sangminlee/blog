---
import "@/styles/global.css";
import "@/styles/typography.css";
import { SITE } from "@/data/site.config";
import {
  getDefaultSocialImage,
  SOCIAL_IMAGE_HEIGHT,
  SOCIAL_IMAGE_WIDTH,
} from "@/utils/social-image";

interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  math?: boolean;
  ogType?: "website" | "article";
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: readonly string[];
  noIndex?: boolean;
}

const {
  title,
  description,
  image,
  imageAlt,
  math = false,
  ogType = "website",
  publishedTime,
  modifiedTime,
  tags,
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = image
  ? new URL(image, Astro.site)
  : new URL(getDefaultSocialImage(), Astro.site);
const socialImageType = socialImageURL.pathname.endsWith(".svg")
  ? "image/svg+xml"
  : "image/png";
const socialImageAlt = imageAlt ?? `${title} 대표 이미지`;
const fullTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
{noIndex && <meta name="robots" content="noindex, follow" />}

<!-- Tell the UA both schemes are supported before any CSS parses, so
     form controls / scrollbars pick the right palette without flashing. -->
<meta name="color-scheme" content="light dark" />

<!-- Mobile URL-bar color matches the body background in each theme -->
<meta name="theme-color" content="#fafaf8" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#08080a" media="(prefers-color-scheme: dark)" />

<!-- Favicon: SVG scales to any density; PNG is the fallback -->
<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
<link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon-32.png`} />

<!-- Canonical URL (omitted on noIndex pages — 404 shouldn't self-canonicalise) -->
{!noIndex && <link rel="canonical" href={canonicalURL} />}

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.author} />

<!-- Open Graph / Facebook — only for pages that should be shareable.
     A 404 (noIndex) shouldn't produce a social preview of the error. -->
{!noIndex && (
  <>
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:type" content={socialImageType} />
    <meta property="og:image:width" content={SOCIAL_IMAGE_WIDTH.toString()} />
    <meta property="og:image:height" content={SOCIAL_IMAGE_HEIGHT.toString()} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:locale" content={SITE.lang} />
    <meta property="og:site_name" content={SITE.title} />
  </>
)}

{!noIndex && ogType === "article" && (
  <>
    {publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}
    <meta property="article:author" content={SITE.author} />
    {tags && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
  </>
)}

{/* JSON-LD structured data. Escape "<" so a title/description that happens
    to contain "</script>" or "<script>" can't break out of the script tag.
    Skipped on noIndex pages so a 404 can't register itself as schema.org
    content in crawlers that read structured data even when robots says no. */}
{!noIndex && (
  <script type="application/ld+json" set:html={JSON.stringify(
    ogType === "article"
      ? {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          headline: title,
          description,
          author: {
            "@type": "Person",
            name: SITE.author,
          },
          publisher: {
            "@type": "Person",
            name: SITE.author,
          },
          ...(publishedTime && { datePublished: publishedTime.toISOString() }),
          ...(modifiedTime && { dateModified: modifiedTime.toISOString() }),
          image: socialImageURL.toString(),
          mainEntityOfPage: {
            "@type": "WebPage",
            "@id": canonicalURL.toString(),
          },
          ...(tags && tags.length > 0 && { keywords: tags.join(", ") }),
          inLanguage: SITE.lang,
        }
      : {
          "@context": "https://schema.org",
          "@type": "WebSite",
          name: SITE.title,
          description: SITE.description,
          url: new URL(SITE.base + "/", Astro.site).toString(),
          inLanguage: SITE.lang,
          author: {
            "@type": "Person",
            name: SITE.author,
          },
        }
  ).replace(/</g, "\\u003c")} />
)}

<!-- Twitter — card type is Twitter-specific; everything else falls back
     to og:title / og:description / og:image automatically. -->
{!noIndex && (
  <>
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image:alt" content={socialImageAlt} />
  </>
)}

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,700;1,400&display=swap"
  rel="stylesheet"
/>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
/>
<link
  href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
  rel="stylesheet"
/>

<!-- KaTeX (conditional). Pinned with Subresource Integrity so a compromised
     CDN response can't silently ship altered CSS to readers. -->
{math && (
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css"
    integrity="sha384-zh0CIslj+VczCZtlzBcjt5ppRcsAmDnRem7ESsYwWwg3m/OaJ2l4x7YBZl9Kxxib"
    crossorigin="anonymous"
    referrerpolicy="no-referrer"
  />
)}

<!-- Sitemap -->
<link rel="sitemap" href={`${import.meta.env.BASE_URL}sitemap-index.xml`} />

<!-- RSS -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE.title}
  href={`${import.meta.env.BASE_URL}rss.xml`}
/>
