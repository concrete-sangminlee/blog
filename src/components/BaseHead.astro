---
import "@/styles/global.css";
import "@/styles/typography.css";
import { SITE } from "@/data/site.config";

interface Props {
  title: string;
  description: string;
  image?: string;
  math?: boolean;
}

const {
  title,
  description,
  image,
  math = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = image
  ? new URL(image, Astro.site)
  : new URL(`${import.meta.env.BASE_URL}og-default.png`, Astro.site);
const fullTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{fullTitle}</title>
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
<meta name="author" content={SITE.author} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:locale" content={SITE.lang} />
<meta property="og:site_name" content={SITE.title} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={fullTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@0,400;0,700;1,400&display=swap"
  rel="stylesheet"
/>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"
/>
<link
  href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
  rel="stylesheet"
/>

<!-- KaTeX (conditional) -->
{math && (
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css"
    crossorigin="anonymous"
  />
)}

<!-- Sitemap -->
<link rel="sitemap" href={`${import.meta.env.BASE_URL}sitemap-index.xml`} />

<!-- RSS -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE.title}
  href={`${import.meta.env.BASE_URL}rss.xml`}
/>
