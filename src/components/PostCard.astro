---
import type { BlogPost } from "@/utils/posts";

interface Props {
  post: BlogPost;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const { title, description, pubDate, tags, featured } = post.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const href = `${import.meta.env.BASE_URL}${post.slug}/`;
const truncatedDesc =
  description.length > 150 ? description.slice(0, 150) + "..." : description;
---

<article
  class="post-card"
  style={`animation-delay: ${index * 80}ms;`}
>
  <a href={href} class="post-card-link">
    <div class="post-card-inner">
      <div class="post-card-meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {featured && <span class="featured-badge">Featured</span>}
      </div>

      <h3 class="post-card-title" transition:name={`title-${post.slug}`}>
        {title}
      </h3>

      <p class="post-card-desc">{truncatedDesc}</p>

      {tags.length > 0 && (
        <div class="post-card-tags">
          {tags.map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  .post-card {
    opacity: 0;
    animation: fadeIn 0.5s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .post-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid transparent;
    position: relative;
    transition: all 0.25s ease;
  }

  .post-card-link:hover {
    background: var(--bg-surface);
    border-color: var(--border);
    color: inherit;
  }

  .post-card-link:hover .post-card-title {
    color: var(--accent);
  }

  .post-card-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.01em;
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.5rem;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-subtle);
    border: 1px solid rgba(232, 168, 73, 0.15);
    border-radius: 9999px;
    font-family: var(--font-body);
  }

  .post-card-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.015em;
    color: var(--text-primary);
    margin: 0;
    transition: color 0.25s ease;
  }

  .post-card-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.25rem;
  }

  .tag-pill {
    display: inline-block;
    padding: 0.1rem 0.55rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 9999px;
    transition: all 0.2s ease;
  }

  .post-card-link:hover .tag-pill {
    border-color: var(--border-hover);
    color: var(--text-secondary);
  }
</style>
