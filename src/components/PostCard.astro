---
import type { BlogPost } from "@/utils/posts";

interface Props {
  post: BlogPost;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const { title, description, pubDate, tags, featured } = post.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const href = `${import.meta.env.BASE_URL}${post.slug}/`;
const truncatedDesc =
  description.length > 140 ? description.slice(0, 140) + "..." : description;
---

<article
  class="post-card"
  style={`animation-delay: ${index * 60}ms;`}
>
  <a href={href} class="post-card-link">
    <div class="post-card-inner">
      <div class="post-card-meta">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {featured && <span class="featured-badge">Featured</span>}
      </div>

      <h3 class="post-card-title" transition:name={`title-${post.slug}`}>
        {title}
      </h3>

      <p class="post-card-desc">{truncatedDesc}</p>

      {tags.length > 0 && (
        <div class="post-card-tags">
          {tags.map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  .post-card {
    opacity: 0;
    animation: fadeInUp 0.4s ease forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .post-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    position: relative;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .post-card-link::before {
    content: "";
    position: absolute;
    left: -1.25rem;
    top: 1.75rem;
    bottom: 0;
    width: 3px;
    background: var(--accent);
    border-radius: 2px;
    opacity: 0;
    transform: scaleY(0.6);
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .post-card-link:hover {
    transform: translateY(-2px);
    color: inherit;
  }

  .post-card-link:hover::before {
    opacity: 1;
    transform: scaleY(1);
  }

  .post-card-link:hover .post-card-title {
    color: var(--accent);
  }

  .post-card-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    background: var(--accent-subtle);
    border-radius: 9999px;
    font-family: var(--font-body);
  }

  .post-card-title {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0;
    transition: color 0.2s ease;
  }

  .post-card-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.25rem;
  }

  .tag-pill {
    display: inline-block;
    padding: 0.125rem 0.625rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 9999px;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .post-card-link:hover .tag-pill {
    border-color: var(--border-hover);
    color: var(--text-secondary);
  }
</style>
