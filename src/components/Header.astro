---
import { NAV_ITEMS } from "@/data/site.config";
import { href as resolveHref } from "@/utils/paths";

const homeHref = resolveHref("/");
const currentPath = Astro.url.pathname;
---

<noscript>
  <!-- The mobile menu is JS-only. Without JS the button would render
       but do nothing, so hide them instead of leaving dead chrome. -->
  <style>
    #mobile-menu-btn { display: none !important; }
    #mobile-nav { display: flex !important; flex-direction: column; }
  </style>
</noscript>

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-[100] transition-all duration-300"
>
  <div class="mx-auto flex max-w-[1200px] items-center justify-between px-6 py-4">
    <!-- Home link -->
    <a
      href={homeHref}
      class="logo-link flex items-center gap-2 transition-colors duration-200"
      aria-label="홈"
    >
      <span class="logo-text hidden sm:inline">Sang Min Lee’s Blog</span>
      <span class="logo-text sm:hidden">SML Blog</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="주 메뉴">
      {NAV_ITEMS.map((item) => {
        const href = resolveHref(item.href);
        const isActive = currentPath === href || currentPath === href.replace(/\/$/, "");
        return (
          <a
            href={href}
            aria-current={isActive ? "page" : undefined}
            class:list={[
              "relative px-3 py-1.5 text-sm font-medium rounded-md transition-all duration-200",
              isActive ? "active-nav-link" : "",
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="mobile-menu-btn md:hidden"
      aria-label="메뉴 전환"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <svg id="menu-icon-open" class="menu-icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="menu-icon-close" class="menu-icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile Navigation -->
  <nav
    id="mobile-nav"
    class="hidden flex-col gap-1 px-6 pb-4 md:hidden"
    aria-label="모바일 메뉴"
  >
    {NAV_ITEMS.map((item) => {
      const href = resolveHref(item.href);
      const isActive = currentPath === href || currentPath === href.replace(/\/$/, "");
      return (
        <a
          href={href}
          aria-current={isActive ? "page" : undefined}
          class:list={[
            "block rounded-md px-3 py-2.5 text-sm font-medium transition-all duration-200",
            isActive ? "active-nav-link" : "",
          ]}
        >
          {item.label}
        </a>
      );
    })}
  </nav>
</header>

<div class="header-spacer"></div>

<style>
  #site-header {
    background-color: transparent;
    /* viewport-fit=cover lets the header extend into iPhone safe-area
       insets. Pad in on every side that can host a cutout: the side
       insets for landscape notches, the top inset so portrait Dynamic
       Island doesn't overlap the logo/nav. */
    padding-top: env(safe-area-inset-top);
    padding-left: env(safe-area-inset-left);
    padding-right: env(safe-area-inset-right);
  }

  /* Takes the same vertical footprint as the fixed header so content
     doesn't scroll under it. 4rem matches the inner div's py-4 + logo
     height; the env() addend matches #site-header's padding-top. */
  .header-spacer {
    height: calc(4rem + env(safe-area-inset-top));
  }

  #site-header.scrolled {
    background-color: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border-bottom: 1px solid var(--border);
  }

  /* Home link */
  .logo-link {
    color: var(--text-primary);
    text-decoration: none;
  }

  .logo-link:hover {
    color: var(--text-primary);
  }

  .logo-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .logo-link:hover .logo-text {
    color: var(--text-primary);
  }

  /* Nav links */
  nav a {
    color: var(--text-muted);
  }

  nav a:hover {
    color: var(--text-primary);
    background: var(--bg-surface);
  }

  /* Scope the active-link rule on nav a so its specificity matches
     nav a:hover and the later-declared colour wins without !important. */
  nav a.active-nav-link,
  nav a.active-nav-link:hover {
    color: var(--accent);
  }

  .active-nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* Mobile menu button */
  .mobile-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    color: var(--text-muted);
    border: 0;
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  @media (max-width: 767.98px) {
    .mobile-menu-btn {
      display: flex;
    }
  }

  .mobile-menu-btn:hover {
    color: var(--text-primary);
  }

  /* Mobile menu icons follow aria-expanded on the toggle button. */
  .menu-icon-close {
    display: none;
  }
  #mobile-menu-btn[aria-expanded="true"] .menu-icon-open {
    display: none;
  }
  #mobile-menu-btn[aria-expanded="true"] .menu-icon-close {
    display: block;
  }

  /* Mobile nav */
  #mobile-nav {
    border-top: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 95%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
</style>

<script>
  let headerController: AbortController | null = null;

  function initHeader() {
    const header = document.getElementById("site-header");
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileNav = document.getElementById("mobile-nav");

    // Tear down listeners from the previous page before rebinding, or
    // we stack a new window scroll handler on every view transition.
    headerController?.abort();
    if (!header || !mobileMenuBtn || !mobileNav) return;
    headerController = new AbortController();
    const { signal } = headerController;

    let isOpen = false;

    function onScroll() {
      if (window.scrollY > 10) {
        header!.classList.add("scrolled");
      } else {
        header!.classList.remove("scrolled");
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true, signal });
    onScroll();

    function setMobileMenu(open: boolean) {
      isOpen = open;
      mobileNav!.classList.toggle("hidden", !open);
      mobileNav!.classList.toggle("flex", open);
      // The open/close SVGs swap via CSS keyed on aria-expanded.
      mobileMenuBtn!.setAttribute("aria-expanded", String(open));
    }

    mobileMenuBtn.addEventListener("click", () => setMobileMenu(!isOpen), { signal });

    mobileNav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setMobileMenu(false), { signal });
    });

    // Escape closes the mobile menu and returns focus to the toggle.
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) {
        setMobileMenu(false);
        mobileMenuBtn!.focus();
      }
    }, { signal });
  }

  initHeader();
  document.addEventListener("astro:after-swap", () => {
    initHeader();
  });
</script>
