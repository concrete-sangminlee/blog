---
import { NAV_ITEMS } from "@/data/site.config";
import { href as resolveHref } from "@/utils/paths";

const homeHref = resolveHref("/");
const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-[100] transition-all duration-300"
>
  <div class="mx-auto flex max-w-[1200px] items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a
      href={homeHref}
      class="logo-link flex items-center gap-2 transition-colors duration-200"
      aria-label="Home"
    >
      <span class="logo-mark">S</span>
      <span class="logo-text hidden sm:inline">Sang Min Lee's Tech Blog</span>
      <span class="logo-text sm:hidden">SML Tech Blog</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {NAV_ITEMS.map((item) => {
        const href = resolveHref(item.href);
        const isActive = currentPath === href || currentPath === href.replace(/\/$/, "");
        return (
          <a
            href={href}
            class:list={[
              "relative px-3 py-1.5 text-sm font-medium rounded-md transition-all duration-200",
              isActive ? "active-nav-link" : "",
            ]}
          >
            {item.label}
          </a>
        );
      })}

      <!-- Search Button -->
      <button
        id="search-btn"
        class="search-btn ml-2"
        aria-label="Search (⌘K)"
        title="Search (⌘K)"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </button>

      <!-- Write Button (opens GitHub editor) -->
      <a
        href="https://github.com/concrete-sangminlee/blog/new/main/src/content/blog"
        target="_blank"
        rel="noopener noreferrer"
        class="search-btn ml-1"
        aria-label="Write post"
        title="Write post"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9" />
          <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
        </svg>
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="mobile-menu-btn md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="menu-icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile Navigation -->
  <nav
    id="mobile-nav"
    class="hidden flex-col gap-1 px-6 pb-4 md:hidden"
    aria-label="Mobile navigation"
  >
    {NAV_ITEMS.map((item) => {
      const href = resolveHref(item.href);
      const isActive = currentPath === href || currentPath === href.replace(/\/$/, "");
      return (
        <a
          href={href}
          class:list={[
            "block rounded-md px-3 py-2.5 text-sm font-medium transition-all duration-200",
            isActive ? "active-nav-link" : "",
          ]}
        >
          {item.label}
        </a>
      );
    })}
  </nav>
</header>

<div class="h-16"></div>

<style>
  #site-header {
    background-color: transparent;
  }

  #site-header.scrolled {
    background-color: rgba(8, 8, 10, 0.85) !important;
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border-bottom: 1px solid var(--border);
  }

  /* Logo */
  .logo-link {
    color: var(--text-primary);
    text-decoration: none;
  }

  .logo-link:hover {
    color: var(--text-primary);
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .logo-link:hover .logo-text {
    color: var(--text-primary);
  }

  /* Nav links */
  nav a {
    color: var(--text-muted);
  }

  nav a:hover {
    color: var(--text-primary) !important;
    background: var(--bg-surface);
  }

  .active-nav-link {
    color: var(--accent) !important;
  }

  .active-nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* Search button */
  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: var(--text-muted);
    border: 1px solid var(--border);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .search-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
    background: var(--bg-surface);
  }

  /* Mobile menu button */
  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    color: var(--text-muted);
    border: 1px solid var(--border);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mobile-menu-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
  }

  /* Mobile nav */
  #mobile-nav {
    border-top: 1px solid var(--border);
    background: rgba(8, 8, 10, 0.95);
    backdrop-filter: blur(16px);
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById("site-header");
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileNav = document.getElementById("mobile-nav");
    const iconOpen = document.getElementById("menu-icon-open");
    const iconClose = document.getElementById("menu-icon-close");

    if (!header || !mobileMenuBtn || !mobileNav || !iconOpen || !iconClose) return;

    let isOpen = false;

    function onScroll() {
      if (window.scrollY > 10) {
        header!.classList.add("scrolled");
      } else {
        header!.classList.remove("scrolled");
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    mobileMenuBtn.addEventListener("click", () => {
      isOpen = !isOpen;
      mobileNav!.classList.toggle("hidden", !isOpen);
      mobileNav!.classList.toggle("flex", isOpen);
      iconOpen!.style.display = isOpen ? "none" : "block";
      iconClose!.style.display = isOpen ? "block" : "none";
      mobileMenuBtn!.setAttribute("aria-expanded", String(isOpen));
    });

    mobileNav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        isOpen = false;
        mobileNav!.classList.add("hidden");
        mobileNav!.classList.remove("flex");
        iconOpen!.style.display = "block";
        iconClose!.style.display = "none";
        mobileMenuBtn!.setAttribute("aria-expanded", "false");
      });
    });
  }

  // Search button triggers SearchModal via custom event
  function initSearch() {
    const searchBtn = document.getElementById("search-btn");
    searchBtn?.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("open-search"));
    });
  }

  initHeader();
  initSearch();
  document.addEventListener("astro:after-swap", () => {
    initHeader();
    initSearch();
  });
</script>
