---
interface Props {
  identifier: string;
  url: string;
  title: string;
}

const { identifier, url, title } = Astro.props;
---

<section class="mt-16" id="comments" aria-labelledby="post-comments-heading">
  <h2 id="post-comments-heading" class="heading-section mb-6 text-lg">Comments</h2>
  <div
    id="disqus_thread"
    data-disqus-identifier={identifier}
    data-disqus-url={url}
    data-disqus-title={title}
  ></div>
</section>

<style>
  /* Match the scroll-margin-top on post headings so /#comments from
     an external link lands below the fixed header, not under it. */
  #comments {
    scroll-margin-top: 5rem;
  }
</style>

<script>
  const DISQUS_SHORTNAME = "sangminlee-blog";

  type PageConfig = {
    identifier: string;
    url: string;
    title: string;
  };

  // Disqus attaches two things to window that aren't in lib.dom: a
  // disqus_config callback and, after embed.js runs, a DISQUS object with
  // a reset method. Type that surface locally so we don't reach for `any`.
  type DisqusConfigCallback = (this: {
    page: { identifier: string; url: string; title: string };
  }) => void;
  type DisqusWindow = Window & {
    disqus_config?: DisqusConfigCallback;
    DISQUS?: {
      reset: (options: { reload: boolean; config: DisqusConfigCallback }) => void;
    };
  };
  const dw = window as DisqusWindow;

  function readPageConfig(): PageConfig | null {
    const container = document.getElementById("disqus_thread");
    if (!container) return null;
    const { disqusIdentifier, disqusUrl, disqusTitle } = container.dataset;
    if (!disqusIdentifier || !disqusUrl) return null;
    return {
      identifier: disqusIdentifier,
      url: disqusUrl,
      title: disqusTitle ?? document.title,
    };
  }

  function loadDisqusScript() {
    const cfg = readPageConfig();
    if (!cfg) return;

    // Set initial config for first load
    dw.disqus_config = function () {
      this.page.identifier = cfg.identifier;
      this.page.url = cfg.url;
      this.page.title = cfg.title;
    };

    if (dw.DISQUS) {
      // Already loaded on a previous page, reset with new page info
      dw.DISQUS.reset({
        reload: true,
        config: function () {
          this.page.identifier = cfg.identifier;
          this.page.url = cfg.url;
          this.page.title = cfg.title;
        },
      });
      return;
    }

    const s = document.createElement("script");
    s.src = `https://${DISQUS_SHORTNAME}.disqus.com/embed.js`;
    s.setAttribute("data-timestamp", String(Date.now()));
    (document.head || document.body).appendChild(s);
  }

  let activeObserver: IntersectionObserver | null = null;

  function initLazyDisqus() {
    const container = document.getElementById("disqus_thread");
    if (!container) return;

    // Drop any observer left watching the previous post's container so we
    // don't leak one per client-side navigation.
    activeObserver?.disconnect();
    activeObserver = null;

    // If DISQUS is already loaded (from a previous page), reset immediately on
    // this new post. Users who navigated here via the client router expect the
    // comments to reflect the current post without needing to scroll.
    if (dw.DISQUS) {
      loadDisqusScript();
      return;
    }

    // First-time load: wait until the comments section is close to the
    // viewport so the embed.js fetch and thread render happen only for
    // readers who actually reach the end of the post.
    activeObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            activeObserver?.disconnect();
            activeObserver = null;
            loadDisqusScript();
            break;
          }
        }
      },
      { rootMargin: "400px 0px" },
    );
    activeObserver.observe(container);
  }

  initLazyDisqus();
  document.addEventListener("astro:after-swap", initLazyDisqus);
</script>

<noscript>댓글을 보려면 JavaScript를 활성화해주세요.</noscript>
