<section class="mt-16" id="comments">
  <h2 class="heading-section mb-6 text-lg">Comments</h2>
  <div id="disqus_thread"></div>
</section>

<script>
  function initDisqus() {
    const container = document.getElementById("disqus_thread");
    if (!container || container.children.length > 0) return;

    const d = document;
    const s = d.createElement("script");
    s.src = "https://sangminlee-blog.disqus.com/embed.js";
    s.setAttribute("data-timestamp", String(+new Date()));
    (d.head || d.body).appendChild(s);
  }

  initDisqus();
  document.addEventListener("astro:after-swap", initDisqus);
</script>

<noscript>댓글을 보려면 JavaScript를 활성화해주세요.</noscript>
