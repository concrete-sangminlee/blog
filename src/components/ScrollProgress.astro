<div
  id="scroll-progress"
  class="fixed top-0 left-0 h-[2px] z-[10000]"
  style="width: 0%; background-color: var(--scroll-progress);"
  aria-hidden="true"
></div>

<script>
  let controller: AbortController | null = null;

  function initScrollProgress() {
    const bar = document.getElementById("scroll-progress");
    if (!bar) return;

    // Detach any listener left over from a previous page so we don't pile up
    // one per view-transition navigation.
    controller?.abort();
    controller = new AbortController();

    function updateProgress() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      if (docHeight <= 0) {
        bar!.style.width = "0%";
        return;
      }
      const progress = Math.min((scrollTop / docHeight) * 100, 100);
      bar!.style.width = `${progress}%`;
    }

    window.addEventListener("scroll", updateProgress, {
      passive: true,
      signal: controller.signal,
    });
    updateProgress();
  }

  initScrollProgress();
  document.addEventListener("astro:after-swap", initScrollProgress);
</script>
