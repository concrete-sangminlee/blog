---
interface Props {
  type?: "info" | "warning" | "tip" | "note";
  title?: string;
}

const { type = "note", title } = Astro.props;

const config: Record<string, { label: string; borderColor: string; bgColor: string; iconColor: string }> = {
  info: {
    label: "Info",
    borderColor: "#3b82f6",
    bgColor: "rgba(59, 130, 246, 0.06)",
    iconColor: "#3b82f6",
  },
  warning: {
    label: "Warning",
    borderColor: "#ef4444",
    bgColor: "rgba(239, 68, 68, 0.06)",
    iconColor: "#ef4444",
  },
  tip: {
    label: "Tip",
    borderColor: "#10b981",
    bgColor: "rgba(16, 185, 129, 0.06)",
    iconColor: "#10b981",
  },
  note: {
    label: "Note",
    borderColor: "var(--accent)",
    bgColor: "var(--accent-subtle)",
    iconColor: "var(--accent)",
  },
};

const c = config[type];
const displayTitle = title || c.label;
---

<aside
  class="callout my-6 rounded-r-lg p-4 pl-5"
  style={`border-left: 3px solid ${c.borderColor}; background: ${c.bgColor};`}
  role="note"
>
  <div class="flex items-center gap-2 mb-2 font-semibold text-sm" style={`color: ${c.iconColor};`}>
    {type === "info" && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <path d="M12 16v-4" />
        <path d="M12 8h.01" />
      </svg>
    )}
    {type === "warning" && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
        <path d="M12 9v4" />
        <path d="M12 17h.01" />
      </svg>
    )}
    {type === "tip" && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
        <path d="M9 18h6" />
        <path d="M10 22h4" />
      </svg>
    )}
    {type === "note" && (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 20h9" />
        <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
      </svg>
    )}
    <span>{displayTitle}</span>
  </div>
  <div class="text-sm leading-relaxed" style={`color: var(--text-secondary);`}>
    <slot />
  </div>
</aside>
